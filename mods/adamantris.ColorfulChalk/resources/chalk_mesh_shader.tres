[gd_resource type="Shader" format=2]

[resource]
code = "shader_type spatial;
render_mode specular_disabled, shadows_disabled;

const float PI = 3.14159265;

uniform float speed: hint_range(0.0, 1.0, 0.01);

void fragment(){
float r = 0.5 + 0.5 * sin((TIME * speed) * 2.0 * PI / 3.0);
float g = 0.5 + 0.5 * sin((TIME * speed) + 2.0 * PI / 3.0);
float b = 0.5 + 0.5 * sin((TIME * speed) + 4.0 * PI / 3.0);
ALBEDO = vec3(r, g, b);
}"
